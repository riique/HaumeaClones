{
  "name": "haumea-clones",
  "version": "1.0.1",
  "description": "Ferramenta profissional de clonagem de canais do Telegram",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron . --dev\"",
    "build:renderer": "vite build",
    "build:python": "pyinstaller --onefile --name haumea-backend --paths . --hidden-import haumea_rpc --distpath ./dist-python backend/server.py",
    "build": "npm run build:python && npm run build:renderer && electron-builder",
    "build:publish": "npm run build:python && npm run build:renderer && electron-builder --publish always",
    "preview": "vite preview"
  },
  "author": "riiquestudies",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/riique/HaumeaClones.git"
  },
  "build": {
    "appId": "com.riique.haumea-clones",
    "productName": "Haumea Clones",
    "electronUpdaterCompatibility": ">=2.16",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "backend/**/*",
      "dist-python/**/*",
      "icon.ico"
    ],
    "extraResources": [
      {
        "from": "dist-python/",
        "to": "backend/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "icon.ico"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "riique",
        "repo": "HaumeaClones",
        "releaseType": "release"
      }
    ]
  },
  "dependencies": {
    "electron-store": "^10.0.1",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.3",
    "@vitejs/plugin-react": "^4.5.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "electron": "^35.2.1",
    "electron-builder": "^26.0.12",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^4.1.3",
    "vite": "^6.3.5",
    "wait-on": "^9.0.4"
  }
}
